pipeline {
    agent { label 'ci' }

    options {
        disableConcurrentBuilds()
        timestamps()
    }

    parameters{
        choice(name: 'ENV', choices: ['dev', 'test'], description: 'Target environment')
        booleanParam(name: 'RUN_TESTS', defaultValue: true, description: 'Run tests?')
        string(name: 'BUILD_VERSION', defaultValue: '1.0.0', description: 'Build version')
    }

    environment {
        IMAGE_NAME = "task-api:local"
        CONTAINER_NAME = "task-api-${BUILD_NUMBER}"
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
                echo "Building version: ${params.BUILD_VERSION} for environment: ${params.ENV}"
            }
        }

        stage('Install dependencies') {
            steps {
                dir('jenkins-app/task-api') {
                    sh 'npm install'
                }
            }
        }

        stage('Run tests') {
            when {
                expression { return params.RUN_TESTS }
            }
            steps {
                dir('jenkins-app/task-api') {
                    sh 'npm test'
                }
            }
        }

        stage('Docker build') {
            steps {
                withCredentials([string(credentialsId: 'docker-registry-token', variable: 'REGISTRY_TOKEN')]) {
                    sh "docker build -t ${IMAGE_NAME} jenkins-app/task-api/"
                    echo "Image built."
                }
            }
        }

        stage('Docker run') {
            steps {
                sh "docker run -d -p 3000:3000 --name ${CONTAINER_NAME} ${IMAGE_NAME}"
                sh "sleep 3"
                sh "curl -f http://localhost:3000/health"
            }
        }
    }

    post {
        success {
            echo "Build succeeded for version: ${params.BUILD_VERSION}"
            archiveArtifacts artifacts: 'jenkins-app/task-api/package.json', fingerprint: true
        }
        failure {
            echo "Build failed for version: ${params.BUILD_VERSION}"
        }
        always {
            echo "Build completed with status: ${currentBuild.currentResult}"
            sh "docker stop ${CONTAINER_NAME} || true"
            sh "docker rm ${CONTAINER_NAME} || true"
        }
    }
}